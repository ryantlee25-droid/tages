{
  "name": "tages",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Persistent codebase memory for AI coding agents. MCP server + CLI + dashboard.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @tages/dashboard dev",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "mcp",
    "ai",
    "coding",
    "memory",
    "codebase",
    "claude-code",
    "cursor",
    "agents"
  ],
  "author": "Ryan Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryantlee25-droid/tages.git"
  },
  "homepage": "https://github.com/ryantlee25-droid/tages",
  "bugs": {
    "url": "https://github.com/ryantlee25-droid/tages/issues"
  }
}
